{
  "name": "cert-manager",
  "version": "1.0.0",
  "description": "桌面证书管理器 - 面向小型团队统一查看和管理证书",
  "main": "dist/main/index.js",
  "scripts": {
    "start": "npm run build && electron .",
    "dev": "tsc && electron .",
    "build": "tsc",
    "package": "npm run build && electron-builder --win --x64",
    "package:dir": "npm run build && electron-builder --win --x64 --dir"
  },
  "author": "CertManager Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/node-forge": "^1.3.14",
    "@types/uuid": "^10.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "node-forge": "^1.3.1",
    "uuid": "^9.0.1"
  },
  "build": {
    "appId": "com.certmanager.app",
    "productName": "证书管理器",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "dist/**/*",
      "src/renderer/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ]
  }
}
